# Bot token from @BotFather
BOT_TOKEN=

# MongoDB connection
MONGO_URI=mongodb://localhost:27017/bot

# Redis connection (optional, falls back to MongoDB directly)
REDIS_URL=redis://localhost:6379

# Webhook URL (public URL where the bot is reachable)
WEBHOOK_URL=https://your-domain.com

# Webhook path (default /tg-webhook)
WEBHOOK_PATH=/tg-webhook

# Server port (default 3000)
SERVER_PORT=3000

# Comma-separated admin Telegram user IDs
ADMIN_IDS=123456,789012

# Chat ID of the private channel (e.g. -100xxxxxxxxx)
TARGET_CHAT_ID=-1001848531117

# Invite link for /rejoin command
CHANNEL_INVITE_LINK=https://t.me/+yourinvitelink

